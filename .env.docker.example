# Copy thành .env.docker rồi điền giá trị thật. File .env.docker KHÔNG commit.

# ── Bắt buộc ────────────────────────────────────────────────────────────────
# Khoá ký JWT + khoá dẫn xuất mã hoá token store (đổi là mọi phiên/token cũ hỏng)
JWT_SECRET=change-me-to-a-long-random-string

# Email admin — đăng nhập email này tự được role admin + ACTIVE
ADMIN_EMAIL=you@example.com

# URL người dùng mở app (redirect sau OAuth, CORS). Local: http://localhost:8080
FRONTEND_URL=http://localhost:8080

# ── Postgres (compose tự nối, đổi nếu cần) ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tab_order_fetcher

# ── Shopify OAuth (tuỳ chọn — app hệ thống fallback; user tự thêm app riêng) ─
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
# URL public của backend cho callback OAuth + đăng ký webhook.
# Qua nginx của frontend thì chính là FRONTEND_URL (nginx proxy /api):
# SHOPIFY_APP_URL=http://localhost:8080

# ── Tuỳ chọn khác ────────────────────────────────────────────────────────────
# TRACK17_API_KEY=            # tự cập nhật DELIVERED theo hãng vận chuyển
# FACEBOOK_APP_ID=            # FB app mặc định (nếu dùng)
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL_DAYS=30
# ORDER_SYNC_INTERVAL_MIN=10

# ── Cổng publish ra host (đổi khi đụng cổng) ────────────────────────────────
# FRONTEND_PORT=8080
# BACKEND_PORT=3001
# DB_PORT=55432

# ── VITE build-time (bake vào frontend khi build image) ─────────────────────
# VITE_FACEBOOK_APP_ID=
